<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zrrd.catcatecutomer.mapper.ProductsMapper">
    <!-- 获取销售数量最多的热门商品 -->
    <select id="getBestSellingProducts" resultType="com.zrrd.catcatecutomer.entity.Products">
        SELECT *
        FROM products
        WHERE is_available = 1
        ORDER BY sales_count DESC, create_time DESC
            LIMIT #{limit}
    </select>
</mapper>
